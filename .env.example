# ─── Application ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SSG-Hackathon

# ─── Platform Setup ─────────────────────────────────────────
# Required for first-run. Generate a strong random value.
# Used once during initial setup to verify the deployment administrator.
# Never exposed to the client. Not stored in the database.
PLATFORM_SETUP_KEY=

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis (Upstash) ────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Feature Flags ──────────────────────────────────────────
NEXT_PUBLIC_ENABLE_SUBMISSIONS=true
NEXT_PUBLIC_ENABLE_JUDGING=true

# ─── Monitoring (optional) ──────────────────────────────────
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=
