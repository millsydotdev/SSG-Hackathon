# ─── Application ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SSG-Hackathon

# ─── Supabase ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Authentication ─────────────────────────────────────────
# Supabase handles auth; additional provider keys go here
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=

# ─── Vercel ─────────────────────────────────────────────────
# VERCEL_URL=auto-populated-in-preview
# VERCEL_ENV=auto-populated-in-preview

# ─── Feature Flags ──────────────────────────────────────────
NEXT_PUBLIC_ENABLE_SUBMISSIONS=true
NEXT_PUBLIC_ENABLE_JUDGING=true

# ─── Rate Limiting ──────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Monitoring ─────────────────────────────────────────────
# SENTRY_DSN=

# ─── Analytics ──────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=

# ─── Security ───────────────────────────────────────────────
# ARGON2_SECRET=
# ENCRYPTION_KEY=
